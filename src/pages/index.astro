            </a>
            <a href="https://portafoliojuanpa.com" target="_blank" rel="noopener noreferrer" aria-label="Sitio">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={icons.globe} />
            </a>

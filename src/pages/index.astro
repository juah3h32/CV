<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Juan Pablo Corona Corona — Frontend Web Developer & UI/UX Designer. Desarrollo web, animaciones, diseño y producción audiovisual." />
  <title>Juan Pablo Corona — Frontend Developer & UI/UX Designer</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <script is:inline>
    // Runs before paint so the theme is correct on first frame, no flash.
    if (localStorage.getItem('theme') === 'light') {
      document.documentElement.setAttribute('data-theme', 'light');
    }
  </script>
</head>
<body>

  <div class="progress-rail" id="progressRail"></div>

  <div class="lightbox" id="lightbox">
    <button class="lightbox-close" id="lightboxClose" aria-label="Cerrar">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="5" x2="19" y2="19"/><line x1="19" y1="5" x2="5" y2="19"/></svg>
    </button>
    <figure class="lightbox-figure">
      <img class="lightbox-img" id="lightboxImg" src="" alt="" />
      <figcaption class="lightbox-caption" id="lightboxCaption"></figcaption>
    </figure>
  </div>

  <header class="nav" id="siteNav">
    <div class="wrap nav-inner">
      <a href="#top" class="brand">JP<span>·</span>Corona</a>
      <nav class="nav-links" id="navLinks">
        {nav.map((item) => (
          <a href={item.href} data-nav>{item.label}</a>
        ))}
      </nav>
      <button class="theme-toggle" id="themeToggle" aria-label="Cambiar tema claro/oscuro">
        <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={icons.sun} />
        <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={icons.moon} />
      </button>
      <div class="nav-cta">
        <a href="/images/cv-juan-pablo-corona.jpg" download class="btn btn-ghost btn-sm">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={icons.download} />
          Descargar CV
        </a>
      </div>
      <button class="nav-toggle" id="navToggle" aria-label="Abrir menú">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  <main id="top">

    <!-- HERO -->
    <section class="hero section--dark">

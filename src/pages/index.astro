      flex-wrap: wrap;
    }
    .timeline-top h3 { font-size: 21px; }
    .timeline-period {
      font-size: 12.5px;
      font-weight: 600;
      color: var(--green-400);
      background: rgba(51,181,134,0.12);
      padding: 5px 12px;
      border-radius: 999px;
      white-space: nowrap;
    }
    .timeline-role {
      margin-top: 6px;
      font-size: 15.5px;
      font-weight: 500;
      color: var(--ink-soft);
    }
    .timeline-points {
      margin-top: 16px;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .timeline-points li {
      font-size: 15.5px;
      color: var(--ink-soft);
      padding-left: 18px;
      position: relative;
      line-height: 1.5;
    }
    .timeline-points li::before {
      content: '';
      position: absolute;
      left: 0; top: 8px;
      width: 5px; height: 5px;
      border-radius: 50%;
      background: var(--green-400);
    }
    .section--dark2 .timeline-points li::before { background: var(--green-400); }

    /* GEAR */
    .gear-marquee {
      position: relative;
      width: 100%;
      overflow: hidden;
      margin-top: 60px;
      padding: 8px 0 4px;
      mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent);
      -webkit-mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent);
    }
    .gear-track {
      display: flex;
      width: max-content;
      gap: 22px;
      animation: marquee-scroll 34s linear infinite;
    }
    .gear-marquee:hover .gear-track { animation-play-state: paused; }
    .gear-card {
      width: 280px;
      flex-shrink: 0;
      padding: 28px 26px;
      border-radius: var(--radius);
      background: rgba(255,255,255,0.045);
      border: 1px solid rgba(255,255,255,0.09);
      color: #fff;
      transition: transform .4s var(--ease), box-shadow .4s var(--ease), background .4s var(--ease), border-color .4s var(--ease);
    }
    .gear-card:hover {
      transform: translateY(-6px);
      background: rgba(255,255,255,0.075);
      border-color: rgba(255,255,255,0.18);
      box-shadow: var(--shadow-lg);
    }
    .gear-card:hover .gear-icon {
      background: var(--green-400-fixed);
      color: var(--green-950);
      transform: scale(1.08) rotate(-4deg);
    }
    .gear-card-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .gear-icon {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 44px; height: 44px;
      border-radius: 12px;
      background: rgba(255,255,255,0.08);
      color: var(--green-300-fixed);
      transition: background .35s var(--ease), color .35s var(--ease), transform .35s var(--ease);
    }
    .gear-icon svg { width: 21px; height: 21px; }
    .gear-count {
      font-family: var(--font-display);
      font-size: 12px;
      font-weight: 700;
      color: rgba(255,255,255,0.4);
      border: 1px solid rgba(255,255,255,0.14);
      border-radius: 999px;
      width: 26px; height: 26px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .gear-card h3 {
      margin-top: 22px;
      font-size: 26px;
      color: var(--green-300-fixed);
    }
    .gear-chips {
      margin-top: 16px;
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    .gear-chips span {
      font-size: 12.5px;
      font-weight: 500;
      color: rgba(255,255,255,0.82);
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.1);
      padding: 6px 12px;
      border-radius: 999px;
      transition: background .3s ease, border-color .3s ease;
    }
    .gear-card:hover .gear-chips span {
      border-color: rgba(51,181,134,0.35);
    }

    /* PROJECTS */
    .project-tabs {
      display: flex;
      gap: 10px;
      margin-bottom: 36px;
    }
    .project-tab {
      padding: 9px 20px;
      border-radius: 999px;
      border: 1px solid var(--line-strong);
      background: transparent;
      color: var(--ink-soft);
      font-size: 13px;
      font-weight: 600;
      transition: background .3s ease, border-color .3s ease, color .3s ease;
    }
    .project-tab:hover { border-color: var(--green-400); color: var(--ink); }
    .project-tab.is-active {
      background: var(--green-500);
      border-color: var(--green-500);
      color: #fff;
    }
    .project-card--empty {
      align-items: center;
      justify-content: center;
      text-align: center;
      border-style: dashed;
      border-color: var(--line-strong);
      background: transparent;
    }
    .project-empty-slot {
      width: 52px; height: 52px;
      margin: 34px auto 0;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 1px dashed var(--line-strong);
      color: var(--ink-faint);
    }
    .project-empty-slot svg { width: 22px; height: 22px; }
    .project-card--empty .project-body { align-items: center; text-align: center; }
    .project-card--empty h3 { font-size: 14px; color: var(--ink-soft); }
    .project-card--empty p { color: var(--ink-faint); font-size: 12.5px; }
    .project-carousel {
      position: relative;
      width: 100%;
      overflow: hidden;
      margin-top: 44px;
      padding: 4px 0 8px;
      mask-image: linear-gradient(90deg, transparent, #000 5%, #000 95%, transparent);
      -webkit-mask-image: linear-gradient(90deg, transparent, #000 5%, #000 95%, transparent);
    }
    .project-track {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 20px;
    }
    .project-track--loop {
      width: max-content;
      flex-wrap: nowrap;
      justify-content: flex-start;
      animation: marquee-scroll 38s linear infinite;
    }
    .project-carousel:hover .project-track--loop { animation-play-state: paused; }
    .project-card {
      width: min(340px, 84vw);
      flex-shrink: 0;
      display: flex;
      flex-direction: column;
      border-radius: var(--radius);
      overflow: hidden;
      border: 1px solid var(--line);
      background: var(--off-white);
      transform-style: preserve-3d;
      transition: box-shadow .4s var(--ease), border-color .4s var(--ease);
    }
    .project-card:hover {
      box-shadow: var(--shadow-lg);
      border-color: var(--green-400);
    }
    .project-thumb {
      height: 140px;
      flex-shrink: 0;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      align-items: flex-start;
      padding: 14px;
      position: relative;
      overflow: hidden;
      background: var(--charcoal-soft);
    }
    .project-thumb--media { height: 190px; }
    .project-thumb-img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: top center;
      transition: transform .6s var(--ease);
    }
    .project-card:hover .project-thumb-img { transform: scale(1.04); }
    .project-thumb.has-image::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(7,10,9,0.85) 0%, rgba(7,10,9,0.15) 55%, transparent 75%);
      z-index: 1;
    }
    .project-thumb.has-image::after { display: none; }
    .project-index {
      position: absolute;
      top: 14px; left: 16px;
      font-family: var(--font-display);
      font-size: 12px;
      color: rgba(255,255,255,0.55);
      z-index: 1;
    }
    .project-thumb-name {
      font-family: var(--font-display);
      font-weight: 700;
      text-transform: uppercase;
      font-size: 15px;
      color: #fff;
      z-index: 1;
      letter-spacing: 0.03em;
      transition: opacity .35s ease;
    }
    .project-card:hover .project-thumb-name { opacity: 0; }
    .project-visit {
      position: absolute;
      inset: 0;
      z-index: 2;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      background: rgba(7, 10, 9, 0.62);
      backdrop-filter: blur(2px);
      color: #fff;
      font-size: 13px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      opacity: 0;
      transform: scale(0.96);
      transition: opacity .4s var(--ease), transform .4s var(--ease);
    }
    .project-visit svg { width: 16px; height: 16px; }
    .project-card:hover .project-visit { opacity: 1; transform: scale(1); }
    .thumb-1 { background: linear-gradient(135deg, var(--green-800), var(--green-500)); }
    .thumb-2 { background: linear-gradient(135deg, var(--green-950), var(--green-700)); }
    .thumb-3 { background: linear-gradient(135deg, var(--green-700), #0b3d35 60%, var(--green-400)); }
    .project-thumb::after {
      content: '';
      position: absolute; inset: 0;
      background-image: radial-gradient(rgba(255,255,255,0.16) 1px, transparent 1px);
      background-size: 16px 16px;
    }
    .project-body {
      display: flex;
      flex-direction: column;
      flex: 1;
      padding: 16px 16px 20px;
    }
    .project-title-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }
    .project-body h3 { font-size: 15.5px; }
    .project-arrow {
      width: 16px; height: 16px;
      flex-shrink: 0;
      color: var(--ink-faint);
      transition: transform .35s var(--ease), color .35s var(--ease);
    }
    .project-card:hover .project-arrow {
      transform: translate(3px, -3px);
      color: var(--green-400);
    }
    .project-body p {
      margin-top: 8px;
      font-size: 13.5px;
      color: var(--ink-soft);
      line-height: 1.5;
    }
    .project-tags {
      margin-top: auto;
      padding-top: 14px;
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
    }
    .project-tags span {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      font-size: 10.5px;
      font-weight: 600;
      padding: 3px 8px 3px 6px;
      border-radius: 6px;
    }
    .project-tags span svg { width: 12px; height: 12px; }

    /* EDUCATION */
    .education-inner {
      display: grid;
      grid-template-columns: 1.3fr 0.7fr;
      gap: 80px;
    }
    .education h2 { font-size: clamp(26px, 3.2vw, 36px); margin-top: 14px; }
    .edu-block {
      margin-top: 30px;
      padding: 26px;
      border-radius: var(--radius);
      background: var(--off-white);
      border: 1px solid var(--line);
    }
    .edu-block h3 { font-size: 17px; }
    .edu-block p { margin-top: 8px; font-size: 15px; color: var(--ink-soft); }
    .edu-period {
      display: inline-block;
      margin-top: 14px;
      font-size: 12px;
      font-weight: 600;
      color: var(--green-400);
    }
    .cert-list {
      margin-top: 26px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .cert-list li {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 15.5px;
      color: var(--ink-soft);
    }
    .cert-check {
      width: 22px; height: 22px;
      border-radius: 50%;
      background: var(--green-500);
      color: #fff;
      font-size: 11px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .lang-bars .bar-row { grid-template-columns: 90px 1fr 52px; margin-top: 30px; }
    .bars-compact { gap: 16px; max-width: none; }
    .bars-compact .bar-row { grid-template-columns: 1fr auto 40px; gap: 12px; }
    .bars-compact .bar-label { font-size: 13.5px; }
    .bars-compact .bar-tag { width: 28px; height: 28px; }
    .bars-compact .bar-tag svg { width: 14px; height: 14px; }
    .bars-compact .bar-track { width: 90px; }
    .bars-compact .bar-pct { width: 34px; height: 34px; font-size: 10px; }

    /* CONTACT */
    .contact-card {
      background: var(--green-900);
      border: 1px solid rgba(255,255,255,0.08);
      color: #fff;
      border-radius: 28px;
      padding: clamp(40px, 6vw, 80px);
      position: relative;
      overflow: hidden;
    }
    .contact-card::before {
      content: '';
      position: absolute;
      top: -30%; right: -10%;
      width: 50%; height: 140%;
      background: radial-gradient(circle, rgba(51,181,134,0.22), transparent 70%);
    }
    .contact-card .eyebrow { color: var(--green-300-fixed); }
    .contact-card .eyebrow::before { background: var(--green-300-fixed); }
    .contact-card h2 {
      font-size: clamp(34px, 5vw, 56px);
      margin-top: 16px;
      color: #fff;
    }
    .contact-card h2 em {
      font-style: normal;
      color: var(--green-300-fixed);
    }
    .contact-lead {
      margin-top: 18px;
      font-size: 17px;
      color: rgba(255,255,255,0.7);
      max-width: 460px;
    }
    .contact-email {
      display: inline-block;
      margin-top: 34px;
      font-family: var(--font-display);
      font-size: clamp(22px, 3vw, 30px);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.03em;
      border-bottom: 2px solid var(--green-500);
      padding-bottom: 4px;
      transition: color .3s ease, border-color .3s ease;
    }
    .contact-email:hover { color: var(--green-300-fixed); border-color: var(--green-300-fixed); }
    .contact-grid {
      position: relative;
      margin-top: 56px;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1px;
      background: rgba(255,255,255,0.12);
      border-radius: 16px;
      overflow: hidden;
    }
    .contact-item {
      background: rgba(255,255,255,0.03);
      padding: 22px 20px;
      display: flex;
      flex-direction: column;
      gap: 8px;
      transition: background .3s ease;
    }
    a.contact-item:hover { background: rgba(255,255,255,0.08); }
    .contact-icon {
      width: 18px; height: 18px;
      color: var(--green-400-fixed);
      margin-bottom: 4px;
    }
    .contact-k {
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.5);
    }
    .contact-v {
      font-size: 15.5px;
      font-weight: 600;
    }

    /* FOOTER */
    .footer {
      padding: 30px 0 40px;
      border-top: 1px solid var(--line);
    }
    .footer-inner {
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 10px;
      font-size: 13px;
      color: var(--ink-faint);
    }

    @media (max-width: 1000px) {
      .about-inner, .education-inner, .tools-columns { grid-template-columns: 1fr; gap: 48px; }
      .bar-row { grid-template-columns: 160px 1fr 44px; gap: 12px; }
      .contact-grid { grid-template-columns: repeat(2, 1fr); }
      .hero-inner { grid-template-columns: 1fr; text-align: center; padding-top: 40px; }
      .hero-photo { order: -1; width: min(300px, 70vw); margin-bottom: 12px; }
      .hero-social, .hero-actions, .hero-tags { justify-content: center; }
      .hero-sub { margin-left: auto; margin-right: auto; }
    }
    @media (max-width: 760px) {
      .stat-grid { grid-template-columns: 1fr 1fr; }
      .contact-grid { grid-template-columns: 1fr; }
      .bar-row { grid-template-columns: 1fr; gap: 8px; }
      .bar-pct { justify-self: start; }
    }
  </style>
</body>
</html>

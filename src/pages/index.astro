    </div>
  </footer>

  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    // Scroll progress rail
    gsap.to('#progressRail', {
      scaleX: 1,
      ease: 'none',
      scrollTrigger: { start: 0, end: 'max', scrub: 0.3 },
    });

    // Nav scroll state
    const siteNav = document.getElementById('siteNav');
    ScrollTrigger.create({
      start: 'top -80',
      onUpdate: (self) => {
        siteNav?.classList.toggle('is-scrolled', self.scroll() > 80);
      },
    });

    // Mobile nav toggle
    const navToggle = document.getElementById('navToggle');
    const navLinks = document.getElementById('navLinks');
    navToggle?.addEventListener('click', () => {
      navLinks?.classList.toggle('is-open');
      navToggle.classList.toggle('is-open');
    });
    navLinks?.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => {
        navLinks.classList.remove('is-open');
        navToggle?.classList.remove('is-open');
      })
    );

    // Light/dark theme toggle
    const themeToggle = document.getElementById('themeToggle');
    themeToggle?.addEventListener('click', () => {
      const isLight = document.documentElement.getAttribute('data-theme') === 'light';
      if (isLight) {
        document.documentElement.removeAttribute('data-theme');
        localStorage.setItem('theme', 'dark');
      } else {
        document.documentElement.setAttribute('data-theme', 'light');
        localStorage.setItem('theme', 'light');
      }
    });

    // Project category tabs
    const projectTabs = document.querySelectorAll('.project-tab');
    const projectTracks = document.querySelectorAll('.project-track');
    projectTabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const filter = tab.getAttribute('data-filter');
        projectTabs.forEach((t) => {
          t.classList.toggle('is-active', t === tab);
          t.setAttribute('aria-selected', t === tab ? 'true' : 'false');
        });
        projectTracks.forEach((track) => {
          track.style.display = track.getAttribute('data-group') === filter ? '' : 'none';
        });
      });
    });

    // Image lightbox
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightboxImg');
    const lightboxCaption = document.getElementById('lightboxCaption');
    const lightboxClose = document.getElementById('lightboxClose');
    const openLightbox = (src, caption) => {
      lightboxImg.setAttribute('src', src);
      lightboxCaption.textContent = caption || '';
      lightbox?.classList.add('is-open');
      document.body.style.overflow = 'hidden';
    };
    const closeLightbox = () => {
      lightbox?.classList.remove('is-open');
      document.body.style.overflow = '';
    };
    document.querySelectorAll('.js-lightbox').forEach((el) => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        openLightbox(el.getAttribute('data-lightbox'), el.getAttribute('data-lightbox-caption'));
      });
    });
    lightboxClose?.addEventListener('click', closeLightbox);
    lightbox?.addEventListener('click', (e) => {
      if (e.target === lightbox) closeLightbox();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeLightbox();
    });

    // Active nav link highlight
    const setActive = (id) => {
      document.querySelectorAll('[data-nav]').forEach((a) => a.classList.remove('is-active'));
      document.querySelector(`[data-nav][href="#${id}"]`)?.classList.add('is-active');
    };
    ScrollTrigger.create({
      trigger: '.hero',
      start: 'top 50%',
      end: 'bottom 50%',
      onToggle: (self) => { if (self.isActive) setActive('top'); },
    });
    const sections = ['about', 'skills', 'experience', 'gear', 'projects', 'contact'];
    sections.forEach((id) => {
      const el = document.getElementById(id);
      if (!el) return;
      ScrollTrigger.create({
        trigger: el,
        start: 'top 50%',
        end: 'bottom 50%',
        onToggle: (self) => { if (self.isActive) setActive(id); },
      });
    });

    // Hero entrance
    const heroTl = gsap.timeline({ defaults: { ease: 'power3.out' } });
    heroTl
      .from('.hero .eyebrow', { y: 20, opacity: 0, duration: 0.6 })
      .from('.hero-name', { y: 36, opacity: 0, duration: 0.8 }, '-=0.4')
      .from('.hero-sub', { y: 24, opacity: 0, duration: 0.7 }, '-=0.4')
      .from('.hero-actions', { y: 20, opacity: 0, duration: 0.6 }, '-=0.45')
      .from('.hero-social', { y: 16, opacity: 0, duration: 0.5 }, '-=0.4')
      .from('.hero-tags', { y: 16, opacity: 0, duration: 0.6 }, '-=0.4')
      .from('.hero-photo-glow', { scale: 0.6, opacity: 0, duration: 1 }, '-=0.9')
      .from('.hero-photo-frame', { scale: 0.7, opacity: 0, duration: 0.7 }, '-=0.7')
      .from('.nav', { y: -30, opacity: 0, duration: 0.6 }, '-=1');

    // Generic reveal-on-scroll
    document.querySelectorAll('[data-reveal]').forEach((el) => {
      gsap.from(el, {
        y: 36,
        opacity: 0,
        duration: 0.9,
        ease: 'power3.out',
        scrollTrigger: { trigger: el, start: 'top 85%' },
      });
    });

    // Stat count-up
    document.querySelectorAll('[data-count]').forEach((el) => {
      const target = parseFloat(el.getAttribute('data-count') || '0');
      const suffix = el.getAttribute('data-suffix') || '';
      const obj = { val: 0 };
      ScrollTrigger.create({
        trigger: el,
        start: 'top 85%',
        once: true,
        onEnter: () => {
          gsap.to(obj, {
            val: target,
            duration: 1.6,
            ease: 'power2.out',
            onUpdate: () => {
              el.textContent = Math.round(obj.val) + suffix;
            },
          });
        },
      });
    });

    // Animated bars
    document.querySelectorAll('.bar-row').forEach((row) => {
      const fill = row.querySelector('.bar-fill');
      const label = row.querySelector('[data-pct-label]');
      const pct = parseFloat(fill?.getAttribute('data-pct') || '0');
      const obj = { val: 0 };
      ScrollTrigger.create({
        trigger: row,
        start: 'top 88%',
        once: true,
        onEnter: () => {
          gsap.to(fill, { width: pct + '%', duration: 1.3, ease: 'power3.out' });
          gsap.to(obj, {
            val: pct,
            duration: 1.3,
            ease: 'power3.out',
            onUpdate: () => {
              if (label) label.textContent = Math.round(obj.val) + '%';
            },
          });
        },
      });
    });

    // Animated tool tiles
    document.querySelectorAll('.tool-tile').forEach((tile) => {
      const fill = tile.querySelector('.tool-tile-fill');
      const label = tile.querySelector('[data-pct-label]');
      const pct = parseFloat(fill?.getAttribute('data-pct') || '0');
      const obj = { val: 0 };
      ScrollTrigger.create({
        trigger: tile,
        start: 'top 88%',
        once: true,
        onEnter: () => {
          gsap.to(fill, { width: pct + '%', duration: 1.3, ease: 'power3.out' });
          gsap.to(obj, {
            val: pct,
            duration: 1.3,
            ease: 'power3.out',
            onUpdate: () => {
              if (label) label.textContent = Math.round(obj.val) + '%';
            },
          });
        },
      });
    });

    // Animated rings
    const RING_R = 52;
    const CIRC = 2 * Math.PI * RING_R;
    document.querySelectorAll('[data-ring]').forEach((svg) => {
      const progress = svg.querySelector('.ring-progress');
      const valueEl = svg.parentElement?.querySelector('[data-ring-value]');
      const pct = parseFloat(svg.getAttribute('data-pct') || '0');
      if (progress) {
        progress.style.strokeDasharray = `${CIRC}`;
        progress.style.strokeDashoffset = `${CIRC}`;
      }
      const obj = { val: 0 };
      ScrollTrigger.create({
        trigger: svg,
        start: 'top 90%',
        once: true,
        onEnter: () => {
          gsap.to(progress, {
            strokeDashoffset: CIRC - (CIRC * pct) / 100,
            duration: 1.5,
            ease: 'power3.out',
          });
          gsap.to(obj, {
            val: pct,
            duration: 1.5,
            ease: 'power3.out',
            onUpdate: () => {
              if (valueEl) valueEl.textContent = Math.round(obj.val) + '%';
            },
          });
        },
      });
    });

    // Timeline stagger
    gsap.utils.toArray('.timeline-item').forEach((item) => {
      gsap.from(item, {
        x: -30,
        opacity: 0,
        duration: 0.8,
        ease: 'power3.out',
        scrollTrigger: { trigger: item, start: 'top 85%' },
      });
    });

    // Project card tilt
    document.querySelectorAll('.project-card').forEach((card) => {
      card.addEventListener('mousemove', (e) => {
        const r = card.getBoundingClientRect();
        const x = e.clientX - r.left - r.width / 2;
        const y = e.clientY - r.top - r.height / 2;
        gsap.to(card, {
          rotateX: -y / 22,
          rotateY: x / 22,
          duration: 0.4,
          ease: 'power2.out',
          transformPerspective: 800,
        });
      });
      card.addEventListener('mouseleave', () => {
        gsap.to(card, { rotateX: 0, rotateY: 0, duration: 0.6, ease: 'power3.out' });
      });
    });
  </script>


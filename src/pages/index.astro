// Only loop-animate a track once it has more than 3 items — with 3 or
// fewer everything already fits without scrolling, so keep it static.
const loopItems = <T,>(arr: T[]) => (arr.length > 3 ? [...arr, ...arr] : arr);

// astro:assets needs static, literal import paths to optimize a file, so at
// build time we just check whether the file actually landed on disk yet —
// no image means we fall back to the gradient placeholder instead of a 404.
// Remote (http/https) images skip this check — the browser loads those
// directly at runtime, there's nothing on disk to verify.
for (const p of projects) {
  if (p.image?.startsWith('http')) continue;
  const onDisk = fs.existsSync(new URL('../../public' + p.image, import.meta.url));
  if (!onDisk) delete (p as any).image;
}

const certifications = [
